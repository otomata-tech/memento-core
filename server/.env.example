# Memento server — copier en .env et remplir
PORT=3007
DATABASE_URL=postgres://tuls:tuls@localhost:5434/memento

# Logto (auth.oto.zone) — à créer (SPA + API resource + M2M + Organizations)
LOGTO_ENDPOINT=https://auth.oto.zone
LOGTO_AUDIENCE=https://api.example.com
MCP_AUDIENCE=https://mcp.example.com/mcp
LOGTO_M2M_APP_ID=
LOGTO_M2M_APP_SECRET=

# Dev local : email injecté pour le transport MCP stdio (pas d'OAuth en local)
MEMENTO_DEV_USER_EMAIL=dev@example.com
